# Supabase — get these from your Supabase project settings (API section)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Drive — folder must be shared as "Anyone with the link can view"
GOOGLE_API_KEY=your-google-drive-api-key
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# App passwords
ACCESS_PASSWORD=the-shared-password-guests-enter
ADMIN_PASSWORD=the-password-to-reset-all-votes
